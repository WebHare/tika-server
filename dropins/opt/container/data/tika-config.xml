<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<properties>
  <!-- https://stackoverflow.com/questions/51655510/how-do-you-enable-the-tesseractocrparser-using-tikaconfig-and-the-tika-command-l?rq=1 -->
  <service-loader dynamic="true" loadErrorHandler="IGNORE"/>
  <encodingDetectors>
    <encodingDetector class="org.apache.tika.detect.DefaultEncodingDetector"/>
  </encodingDetectors>
  <translator class="org.apache.tika.language.translate.DefaultTranslator"/>
  <detectors>
    <detector class="org.apache.tika.detect.DefaultDetector"/>
  </detectors>
  <parsers>
    <parser class="org.apache.tika.parser.DefaultParser"/>
    <parser class="org.apache.tika.parser.pdf.PDFParser">
      <params>
        <!-- <param name="extractInlineImages" type="bool">true</param> explicitly setting is stills afer ..-->
      </params>
    </parser>
  </parsers>
    <server>
      <params>
        <!-- which port to start the server on. If you specify a range, e.g. 9995-9998, TikaServerCli will start four forked servers,
        one at each port.  You can also specify multiple forked servers via a comma-delimited value: 9995,9997.-->
        <port>9998</port>
        <host>0.0.0.0</host>

        <taskTimeoutMillis>100000</taskTimeoutMillis>
        </params>
    </server>
</properties>
